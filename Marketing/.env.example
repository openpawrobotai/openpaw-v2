# Copy to .env (gitignored). Names only — never commit real values.
# Run `bash scripts/setup-channels.sh` to fill these interactively.

# --- Channel A: instant build-log feed (Discord + Telegram) ---
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Channel B: curated X devlog (drafted by Gemini, posted after approval) ---
GEMINI_API_KEY=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# Queue backend: local (git-tracked queue/queue.jsonl, default) | sheet | firebase
QUEUE_BACKEND=local
FIREBASE_PROJECT_ID=
GOOGLE_SHEET_ID=
